{
  "info": {
    "name": "Workflow Engine API Tests",
    "description": "Manual test suite for the MSK clinical workflow engine",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": []
  },
  "item": [
    {
      "name": "Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Response is valid JSON', function () {",
              "    pm.expect(pm.response.json()).to.eql({ ok: true });",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8000/health",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["health"]
        }
      }
    },
    {
      "name": "Create MSK Workflow",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "if (!pm.environment.get('mskIdempotencyKey')) {",
              "    pm.environment.set('mskIdempotencyKey', 'user_456_' + Date.now());",
              "}",
              "if (!pm.environment.get('mskPatientId')) {",
              "    pm.environment.set('mskPatientId', 'patient_001');",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const responseBody = pm.response.json();",
              "pm.test('Status code is 202 Accepted', function () {",
              "    pm.response.to.have.status(202);",
              "});",
              "pm.test('Response returns workflow_id and INITIATED status', function () {",
              "    pm.expect(responseBody).to.have.property('workflow_id');",
              "    pm.expect(responseBody.workflow_id).to.not.be.empty;",
              "    pm.expect(responseBody).to.have.property('status', 'INITIATED');",
              "});",
              "pm.test('Stores workflowId for follow-up requests', function () {",
              "    pm.environment.set('workflowId', responseBody.workflow_id);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"idempotencyKey\": \"{{mskIdempotencyKey}}\",\n  \"payload\": {\n    \"symptom\": \"lower back pain\",\n    \"pain_level\": 3,\n    \"duration\": \"2 weeks\",\n    \"red_flags\": false,\n    \"age\": 34,\n    \"patient_id\": \"{{mskPatientId}}\",\n    \"failed_pt_history\": false\n  }\n}"
        },
        "url": {
          "raw": "http://localhost:8000/api/v1/workflows",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "v1", "workflows"]
        }
      }
    },
    {
      "name": "Get Workflow State",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const responseBody = pm.response.json();",
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Returns clinical workflow summary fields', function () {",
              "    pm.expect(responseBody).to.have.property('id');",
              "    pm.expect(responseBody).to.have.property('status');",
              "    pm.expect(responseBody).to.have.property('pathway_selected');",
              "    pm.expect(responseBody).to.have.property('recommended_care');",
              "    pm.expect(responseBody).to.have.property('is_adhered');",
              "    pm.expect(responseBody).to.have.property('is_leakage');",
              "    pm.expect(responseBody).to.have.property('is_overridden');",
              "    pm.expect(responseBody).to.have.property('contextData');",
              "});",
              "pm.test('Status is valid', function () {",
              "    const validStates = ['INITIATED', 'ROUTING', 'DECISION_PENDING', 'ACTION_QUEUED', 'COMPLETED', 'FAILED'];",
              "    pm.expect(validStates).to.include(responseBody.status);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8000/api/v1/workflows/{{workflowId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "v1", "workflows", "{{workflowId}}"]
        }
      }
    },
    {
      "name": "Get Workflow Logs",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const responseBody = pm.response.json();",
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Returns timeline and summary', function () {",
              "    pm.expect(responseBody).to.have.property('workflowId');",
              "    pm.expect(responseBody).to.have.property('traceId');",
              "    pm.expect(responseBody).to.have.property('timeline');",
              "    pm.expect(responseBody.timeline).to.be.an('array');",
              "    pm.expect(responseBody).to.have.property('summary');",
              "});",
              "pm.test('Timeline entries contain narratives', function () {",
              "    pm.expect(responseBody.timeline.length).to.be.greaterThan(0);",
              "    responseBody.timeline.forEach(function (entry) {",
              "        pm.expect(entry).to.have.property('timestamp');",
              "        pm.expect(entry).to.have.property('stage');",
              "        pm.expect(entry).to.have.property('narrative');",
              "    });",
              "});",
              "pm.test('Summary reflects MSK flow fields', function () {",
              "    pm.expect(responseBody.summary).to.have.property('pathway_selected');",
              "    pm.expect(responseBody.summary).to.have.property('recommended_care');",
              "    pm.expect(responseBody.summary).to.have.property('action_taken');",
              "    pm.expect(responseBody.summary).to.have.property('is_adhered');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8000/api/v1/workflows/{{workflowId}}/logs",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "v1", "workflows", "{{workflowId}}", "logs"]
        }
      }
    },
    {
      "name": "Reuse Idempotency Key",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const responseBody = pm.response.json();",
              "pm.test('Status code is 202 Accepted', function () {",
              "    pm.response.to.have.status(202);",
              "});",
              "pm.test('Same idempotency key returns a workflow response', function () {",
              "    pm.expect(responseBody).to.have.property('workflow_id');",
              "    pm.expect(responseBody).to.have.property('status', 'INITIATED');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"idempotencyKey\": \"{{mskIdempotencyKey}}\",\n  \"payload\": {\n    \"symptom\": \"lower back pain\",\n    \"pain_level\": 3,\n    \"duration\": \"2 weeks\",\n    \"red_flags\": false,\n    \"age\": 34,\n    \"patient_id\": \"{{mskPatientId}}\",\n    \"failed_pt_history\": false\n  }\n}"
        },
        "url": {
          "raw": "http://localhost:8000/api/v1/workflows",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "v1", "workflows"]
        }
      }
    }
  ]
}
