    {
      "name": "Get Workflow Status - Immediate (Test 1)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Response has id field', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('id');",
              "});",
              "pm.test('Response has status field', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('status');",
              "});",
              "pm.test('Status is one of the valid states', function () {",
              "    var jsonData = pm.response.json();",
              "    var validStates = ['INITIATED', 'ROUTING', 'DECISION_PENDING', 'ACTION_QUEUED', 'COMPLETED', 'FAILED'];",
              "    pm.expect(validStates).to.include(jsonData.status);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8000/api/v1/workflows/{{workflowId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "v1", "workflows", "{{workflowId}}"]
        }
      }
    },
    {
      "name": "Get Workflow Status - After 2 Seconds (Test 1)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "setTimeout(function() {}, 2000);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Workflow may have progressed state', function () {",
              "    var jsonData = pm.response.json();",
              "    var validStates = ['INITIATED', 'ROUTING', 'DECISION_PENDING', 'ACTION_QUEUED', 'COMPLETED', 'FAILED'];",
              "    pm.expect(validStates).to.include(jsonData.status);",
              "});",
              "pm.test('contextData is present', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.contextData).to.exist;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8000/api/v1/workflows/{{workflowId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "v1", "workflows", "{{workflowId}}"]
        }
      }
    },
    {
      "name": "Get Workflow Logs (Test 1)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Response is an array', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.be.an('array');",
              "});",
              "pm.test('Each log entry has required fields', function () {",
              "    var jsonData = pm.response.json();",
              "    jsonData.forEach(function(log) {",
              "        pm.expect(log).to.have.property('id');",
              "        pm.expect(log).to.have.property('workflowId');",
              "        pm.expect(log).to.have.property('fromState');",
              "        pm.expect(log).to.have.property('toState');",
              "        pm.expect(log).to.have.property('actor');",
              "    });",
              "});",
              "pm.test('Logs are ordered by timestamp', function () {",
              "    var jsonData = pm.response.json();",
              "    for (var i = 1; i < jsonData.length; i++) {",
              "        var prev = new Date(jsonData[i-1].createdAt);",
              "        var curr = new Date(jsonData[i].createdAt);",
              "        pm.expect(prev.getTime()).to.be.lessThanOrEqual(curr.getTime());",
              "    }",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8000/api/v1/workflows/{{workflowId}}/logs",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "v1", "workflows", "{{workflowId}}", "logs"]
        }
      }
    },
