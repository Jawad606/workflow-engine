          "script": {
            "exec": [
              "pm.test('Status code is 400 Bad Request', function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "pm.test('Error message about missing header', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.error).to.include('Idempotency-Key');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
